# Rust + GTK4 build environment for compiling and testing the Darkroom
# workspace (darkroom-core, darkroom-db, darkroom-ui, darkroom-rs).
#
# Use:
#   docker build -t darkroom-rust-dev -f docker/Dockerfile.rust-dev .
#   docker run --rm -v "$PWD:/src" -w /src darkroom-rust-dev cargo check --workspace
#   docker run --rm -v "$PWD:/src" -w /src darkroom-rust-dev cargo test  --workspace --release
#
# The persistent image avoids re-installing Rust + GTK4 dev libs on every
# cargo invocation. Re-run `docker build` only when this file changes.

FROM ubuntu:24.04

ENV DEBIAN_FRONTEND=noninteractive

RUN apt-get update && apt-get install -y --no-install-recommends \
    build-essential cmake pkg-config curl ca-certificates git \
    # GTK4 + libadwaita (needed by darkroom-ui)
    libgtk-4-dev libadwaita-1-dev \
    # cairo / pango / gdk-pixbuf — pulled in transitively but make explicit
    libcairo2-dev libpango1.0-dev libgdk-pixbuf-2.0-dev \
    # graphene (libadwaita transitive)
    libgraphene-1.0-dev \
    # commonly needed by FFI crates that the workspace will accrete
    libsqlite3-dev libssl-dev zlib1g-dev libclang-dev clang \
    libfontconfig-dev libfreetype-dev \
    && rm -rf /var/lib/apt/lists/*

# Install Rust stable
RUN curl --proto '=https' --tlsv1.2 -sSf https://sh.rustup.rs \
    | sh -s -- -y --default-toolchain stable --profile minimal \
        --component clippy --component rustfmt \
    && rm -rf /root/.rustup/toolchains/*/share/doc
ENV PATH="/root/.cargo/bin:${PATH}"

# Pre-create a cargo target dir that can be bind-mounted from the host for
# incremental builds.
ENV CARGO_TARGET_DIR=/cargo-target
RUN mkdir -p "$CARGO_TARGET_DIR"

WORKDIR /src

CMD ["cargo", "check", "--workspace"]
