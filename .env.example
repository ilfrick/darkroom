# Copy this file to .env and adjust the values for your system.
# Docker Compose reads .env automatically.

# Match your host user so mounted files have the right ownership.
# Run: id -u   to get your UID
#      id -g   to get your GID
PUID=1000
PGID=1000

# Timezone (affects file timestamps inside the container)
TZ=Europe/Rome

# Path to your photo library on the host
PHOTOS_DIR=~/Pictures

# Path where Darkroom stores its config and cache on the host
CONFIG_DIR=~/.config/darkroom-docker
